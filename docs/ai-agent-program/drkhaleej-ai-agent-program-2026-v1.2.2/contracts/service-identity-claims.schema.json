{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:drkhaleej:schema:service-identity-claims:1.2.2",
  "title": "DrKhaleej Service Identity Claims",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "iss", "sub", "aud", "scopes",
    "iat", "nbf", "exp", "jti", "body_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.2.2" },
    "iss": { "type": "string", "minLength": 1, "maxLength": 200 },
    "sub": { "type": "string", "minLength": 1, "maxLength": 200 },
    "aud": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "job:create", "job:read", "job:lease", "job:execute",
          "job:heartbeat", "job:complete", "draft:write",
          "evidence:write", "report:write"
        ]
      }
    },
    "iat": { "type": "integer", "minimum": 0 },
    "nbf": { "type": "integer", "minimum": 0 },
    "exp": { "type": "integer", "minimum": 0 },
    "jti": { "type": "string", "format": "uuid" },
    "body_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "job_id": { "type": "string", "format": "uuid" },
    "lease_epoch": { "type": "integer", "minimum": 1 }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scopes": {
            "type": "array",
            "contains": {
              "enum": ["job:execute", "job:heartbeat", "job:complete", "draft:write", "evidence:write"]
            }
          }
        },
        "required": ["scopes"]
      },
      "then": {
        "required": ["job_id", "lease_epoch"],
        "properties": {
          "job_id": true,
          "lease_epoch": true
        }
      }
    }
  ]
}
