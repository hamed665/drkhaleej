{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:drkhaleej:schema:article-draft:1.2.2",
  "title": "DrKhaleej Proposed Article Revision Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "policy_version", "article_id", "revision_id", "locale",
    "state", "medical_sensitivity", "intent", "title", "body_markdown",
    "sources", "claims", "quality_gates", "generated_by", "created_at"
  ],
  "properties": {
    "schema_version": { "const": "1.2.2" },
    "policy_version": { "type": "string", "minLength": 1, "maxLength": 80 },
    "article_id": { "type": "string", "format": "uuid" },
    "revision_id": { "type": "string", "format": "uuid" },
    "paired_revision_id": {
      "oneOf": [
        { "type": "string", "format": "uuid" },
        { "type": "null" }
      ]
    },
    "locale": { "type": "string", "enum": ["en", "ar"] },
    "state": {
      "type": "string",
      "enum": ["idea", "researched", "brief_ready", "drafted", "editorial_review", "medical_review"]
    },
    "medical_sensitivity": { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "intent": { "type": "string", "minLength": 1, "maxLength": 500 },
    "primary_keyword": { "type": "string", "maxLength": 200 },
    "secondary_keywords": {
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 300 },
    "meta_title": { "type": "string", "maxLength": 300 },
    "meta_description": { "type": "string", "maxLength": 600 },
    "body_markdown": { "type": "string", "minLength": 1, "maxLength": 200000 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source" }
    },
    "claims": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/claim" }
    },
    "internal_link_candidates": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/internalLinkCandidate" }
    },
    "quality_gates": { "$ref": "#/$defs/qualityGates" },
    "generated_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_type", "actor_id", "prompt_version"],
      "properties": {
        "actor_type": { "type": "string", "enum": ["agent", "admin", "editor"] },
        "actor_id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "prompt_version": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id", "url", "trust_tier", "locale", "citation_scope",
        "medical_sensitivity", "supported_claim_ids", "conflicts",
        "retrieved_at", "terms_policy_id"
      ],
      "properties": {
        "source_id": { "type": "string", "format": "uuid" },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://",
          "maxLength": 2000
        },
        "publisher": { "type": "string", "maxLength": 300 },
        "trust_tier": { "type": "string", "enum": ["T1", "T2", "T3", "T4", "T5"] },
        "locale": { "type": "string", "enum": ["en", "ar"] },
        "citation_scope": {
          "type": "string",
          "enum": ["identity", "factual", "medical", "editorial", "statistical"]
        },
        "medical_sensitivity": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "supported_claim_ids": {
          "type": "array",
          "maxItems": 200,
          "uniqueItems": true,
          "items": { "type": "string", "format": "uuid" }
        },
        "conflicts": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        },
        "published_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "terms_policy_id": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "claim", "source_ids", "medical", "review_requirement"],
      "properties": {
        "claim_id": { "type": "string", "format": "uuid" },
        "claim": { "type": "string", "minLength": 1, "maxLength": 3000 },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "format": "uuid" }
        },
        "medical": { "type": "boolean" },
        "review_requirement": { "type": "string", "enum": ["editorial", "medical"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "medical": { "const": true } },
            "required": ["medical"]
          },
          "then": {
            "properties": { "review_requirement": { "const": "medical" } }
          }
        }
      ]
    },
    "internalLinkCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "target_type", "eligibility"],
      "properties": {
        "target_id": { "type": "string", "format": "uuid" },
        "target_type": { "type": "string", "enum": ["entity", "article", "category"] },
        "eligibility": { "type": "string", "enum": ["eligible", "ineligible", "needs_review"] },
        "reason": { "type": "string", "maxLength": 500 }
      }
    },
    "qualityGates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seo", "editorial", "medical", "citations", "bilingual_parity", "duplication"],
      "properties": {
        "seo": { "type": "string", "enum": ["pending", "pass", "fail"] },
        "editorial": { "type": "string", "enum": ["pending", "fail"] },
        "medical": { "type": "string", "enum": ["not_required", "pending", "fail"] },
        "citations": { "type": "string", "enum": ["pending", "pass", "fail"] },
        "bilingual_parity": { "type": "string", "enum": ["not_required", "pending", "pass", "fail"] },
        "duplication": { "type": "string", "enum": ["pending", "pass", "fail"] }
      }
    }
  }
}
